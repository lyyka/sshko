#!/usr/bin/env python3
"""Zero-install launcher for sshko.

This thin shim lets the repo run directly (e.g. via a symlink on PATH) without
installing the package or having `uv` available. It puts the bundled `src/` on
sys.path, then hands off to the real entry point in `sshko.cli`.

For a managed install instead, use `uv tool install .` or `pipx install .`,
which expose the same `sshko` command via the [project.scripts] entry point.
"""

import os
import sys

# Resolve symlinks so the launcher finds `src/` even when invoked via a symlink
# placed on PATH (e.g. ~/.local/bin/sshko -> this file).
_REPO_ROOT = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, os.path.join(_REPO_ROOT, "src"))

from sshko.cli import main  # noqa: E402  (import must follow the sys.path tweak)

if __name__ == "__main__":
    sys.exit(main())
